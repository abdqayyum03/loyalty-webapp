# ─── Backend environment variables ───────────────────────────────
# Copy this file to `backend/.env` and fill in your own values.

# MongoDB connection string (e.g. a MongoDB Atlas cluster URI)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/loyaltysystem

# Server
PORT=5000

# JSON Web Token signing
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1d

NODE_ENV=development

# Email (Gmail App Password recommended) — used for OTP / receipt emails
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com

# Google OAuth 2.0 credentials (Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Where the React app runs (used for OAuth redirects)
FRONTEND_URL=http://localhost:3000
